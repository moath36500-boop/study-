<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>إنجاز - النسخة المضيئة 🔋✨</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        body { font-family: 'Tajawal', sans-serif; background-color: #f0f9ff; color: #1e293b; user-select: none; -webkit-tap-highlight-color: transparent; overflow: hidden; }
        .tablet-container { display: grid; grid-template-columns: 280px 1fr; height: 100vh; }
        .sidebar { background: white; border-left: 1px solid #e0f2fe; display: flex; flex-direction: column; padding: 1.25rem; overflow-y: auto; }
        .content-area { overflow-y: auto; padding: 1.5rem; background: #f8fafc; }
        .subject-page { display: none; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; animation: fadeIn 0.3s ease; }
        .subject-page.active { display: grid; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        
        .day-card { background: white; border-radius: 1.5rem; padding: 1.25rem; border: 1px solid #e2e8f0; display: flex; flex-direction: column; justify-content: space-between; min-height: 180px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); }
        .day-card.completed { border-color: #10b981; background: #f0fdf4; }
        
        .btn-control { width: 65px; height: 65px; border-radius: 1.25rem; display: flex; align-items: center; justify-content: center; cursor: pointer; border: none; font-size: 24px; transition: all 0.2s; }
        .btn-minus { background-color: #f1f5f9; color: #64748b; }
        .btn-plus { background-color: #10b981; color: white; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2); }

        .battery-outer { position: relative; width: 90px; height: 160px; margin: 0 auto 1.5rem; border: 3px solid #cbd5e1; border-radius: 12px; padding: 3px; display: flex; align-items: flex-end; background: #f8fafc; }
        .battery-tip { position: absolute; top: -10px; left: 50%; transform: translateX(-50%); width: 30px; height: 8px; background: #cbd5e1; border-radius: 3px 3px 0 0; }
        .battery-fill { width: 100%; transition: all 0.8s ease; border-radius: 6px; position: relative; overflow: hidden; min-height: 2px; }
        .pct-label { position: absolute; width: 100%; top: 50%; left: 0; transform: translateY(-50%); text-align: center; font-weight: 900; font-size: 18px; color: #1e293b; z-index: 10; }
        
        .nav-link { display: flex; flex-direction: column; padding: 0.8rem; border-radius: 1.2rem; color: #64748b; margin-bottom: 0.5rem; width: 100%; text-align: right; border: 1px solid transparent; }
        .nav-link.active { background: #f1f5f9; border-color: #e2e8f0; color: #0f172a; }
        
        .exam-box { padding: 0.75rem; border-radius: 1rem; border: 1px solid #e2e8f0; margin-bottom: 0.5rem; }
        
        /* زر إعادة التعيين */
        .btn-reset { margin-top: auto; display: flex; align-items: center; justify-content: center; gap: 8px; padding: 12px; background: #fff1f2; color: #e11d48; border-radius: 1rem; font-weight: 800; font-size: 12px; border: 1px solid #ffe4e6; transition: all 0.2s; cursor: pointer; }
        .btn-reset:hover { background: #ffe4e6; }
    </style>
</head>
<body>

    <div class="tablet-container">
        <aside class="sidebar">
            <div class="mb-6 text-center pt-2">
                <div class="battery-outer">
                    <div class="battery-tip"></div>
                    <div id="bat-fill" class="battery-fill" style="height: 0%; background: #ef4444;"></div>
                    <div class="pct-label" id="pct-val">0%</div>
                </div>
                <p id="overall-status" class="text-[11px] font-bold text-slate-400">ابدأ الشحن الآن ⚡</p>
            </div>

            <nav class="flex-1 space-y-1">
                <button onclick="tab('math')" id="b-math" class="nav-link active">
                    <span class="font-bold flex items-center gap-2 text-blue-600"><i data-lucide="calculator" class="w-4 h-4"></i> الرياضيات</span>
                    <div class="flex justify-between mt-1 text-[10px] font-bold text-slate-400"><span id="stat-done-math">تم: 0</span> <span id="stat-rem-math">باقي: 0</span></div>
                </button>
                <button onclick="tab('physics')" id="b-physics" class="nav-link">
                    <span class="font-bold flex items-center gap-2 text-yellow-600"><i data-lucide="zap" class="w-4 h-4"></i> الفيزياء</span>
                    <div class="flex justify-between mt-1 text-[10px] font-bold text-slate-400"><span id="stat-done-physics">تم: 0</span> <span id="stat-rem-physics">باقي: 0</span></div>
                </button>
                <button onclick="tab('chem')" id="b-chem" class="nav-link">
                    <span class="font-bold flex items-center gap-2 text-orange-500"><i data-lucide="flask-conical" class="w-4 h-4"></i> الكيمياء</span>
                    <div class="flex justify-between mt-1 text-[10px] font-bold text-slate-400"><span id="stat-done-chem">تم: 0</span> <span id="stat-rem-chem">باقي: 0</span></div>
                </button>
                <button onclick="tab('bio')" id="b-bio" class="nav-link">
                    <span class="font-bold flex items-center gap-2 text-emerald-600"><i data-lucide="microscope" class="w-4 h-4"></i> الأحياء</span>
                    <div class="flex justify-between mt-1 text-[10px] font-bold text-slate-400"><span id="stat-done-bio">تم: 0</span> <span id="stat-rem-bio">باقي: 0</span></div>
                </button>
            </nav>

            <div class="pt-4 border-t border-slate-100 space-y-2 mb-4">
                <div class="exam-box bg-orange-50 border-orange-100">
                    <p class="text-[9px] font-bold text-orange-500 uppercase">الفترة الأولى</p>
                    <div class="flex items-baseline gap-1"><span id="countdown-1" class="text-xl font-black text-orange-600">--</span><span class="text-[9px] font-bold text-orange-400">يوم</span></div>
                </div>
                <div class="exam-box bg-blue-50 border-blue-100">
                    <p class="text-[9px] font-bold text-blue-500 uppercase">الفترة الثانية</p>
                    <div class="flex items-baseline gap-1"><span id="countdown-2" class="text-xl font-black text-blue-600">--</span><span class="text-[9px] font-bold text-blue-400">يوم</span></div>
                </div>
            </div>

            <button onclick="resetApp()" class="btn-reset">
                <i data-lucide="refresh-ccw" class="w-4 h-4"></i>
                إعادة تعيين البيانات
            </button>
        </aside>

        <main class="content-area">
            <div id="p-math" class="subject-page active"></div>
            <div id="p-physics" class="subject-page"></div>
            <div id="p-chem" class="subject-page"></div>
            <div id="p-bio" class="subject-page"></div>
        </main>
    </div>

    <script>
        const plan = {
            math: { start: 1, ranges: ["92-99", "100-107", "108-115", "116-123", "124-131", "132-139", "140-147", "148-155", "156-163", "164-171", "172-177"] },
            physics: { start: 12, ranges: ["8-17", "18-27", "28-37", "38-47", "48-57", "58-67", "68-77", "78-89"] },
            chem: { start: 20, ranges: ["180-189", "190-199", "200-209", "210-219", "220-229", "230-239", "240-250", "251-262"] },
            bio: { start: 28, ranges: ["266-276", "277-287", "288-298", "299-309", "310-320", "321-331", "332-342", "343-352"] }
        };

        const examDates = { period1: '2026-05-15', period2: '2026-06-01' };
        let storage = JSON.parse(localStorage.getItem('study_v17')) || { prog: {} };
        let holdTimer;

        function startHold(id, delta, total) { changeVal(id, delta, total); holdTimer = setInterval(() => changeVal(id, delta, total), 150); }
        function stopHold() { clearInterval(holdTimer); }

        function init() {
            Object.keys(plan).forEach(sub => {
                const container = document.getElementById(`p-${sub}`);
                container.innerHTML = ''; 
                plan[sub].ranges.forEach((rng, i) => {
                    const dId = plan[sub].start + i;
                    const rParts = rng.split('-');
                    const totalPages = parseInt(rParts[1]) - parseInt(rParts[0]) + 1;
                    const cur = storage.prog[dId] || 0;
                    container.innerHTML += `
                        <div class="day-card ${cur >= totalPages ? 'completed' : ''}" id="card-${dId}">
                            <div class="flex justify-between items-start"><span class="bg-slate-100 text-slate-500 font-bold px-3 py-1 rounded-lg text-[11px]">يوم ${dId}</span><div class="text-right"><p class="text-xl font-black text-slate-800 leading-none">صـ ${rng}</p><p class="text-[11px] text-slate-400 font-bold mt-1" id="stats-${dId}">${cur}/${totalPages} صفحة</p></div></div>
                            <div class="flex items-center justify-between mt-6 px-2">
                                <button onmousedown="startHold(${dId},-1,${totalPages})" onmouseup="stopHold()" onmouseleave="stopHold()" ontouchstart="event.preventDefault(); startHold(${dId},-1,${totalPages})" ontouchend="stopHold()" class="btn-control btn-minus">-</button>
                                <span class="text-4xl font-black text-slate-800" id="count-${dId}">${cur}</span>
                                <button onmousedown="startHold(${dId},1,${totalPages})" onmouseup="stopHold()" onmouseleave="stopHold()" ontouchstart="event.preventDefault(); startHold(${dId},1,${totalPages})" ontouchend="stopHold()" class="btn-control btn-plus">+</button>
                            </div>
                        </div>`;
                });
            });
            updateUI();
            lucide.createIcons();
        }

        function changeVal(id, delta, total) {
            let val = (storage.prog[id] || 0) + delta;
            if (val < 0) val = 0; if (val > total) val = total;
            storage.prog[id] = val;
            document.getElementById(`count-${id}`).innerText = val;
            document.getElementById(`stats-${id}`).innerText = `${val}/${total} صفحة`;
            const card = document.getElementById(`card-${id}`);
            val >= total ? card.classList.add('completed') : card.classList.remove('completed');
            updateUI();
        }

        function updateUI() {
            let totalPagesOverall = 0, totalDoneOverall = 0;
            Object.keys(plan).forEach(sub => {
                let subTotal = 0, subDone = 0;
                plan[sub].ranges.forEach((rng, i) => {
                    const dId = plan[sub].start + i;
                    subTotal += (parseInt(rng.split('-')[1]) - parseInt(rng.split('-')[0]) + 1);
                    subDone += (storage.prog[dId] || 0);
                });
                document.getElementById(`stat-done-${sub}`).innerText = `تم: ${subDone}`;
                document.getElementById(`stat-rem-${sub}`).innerText = `باقي: ${subTotal - subDone}`;
                totalPagesOverall += subTotal; totalDoneOverall += subDone;
            });

            const pct = Math.round((totalDoneOverall / totalPagesOverall) * 100) || 0;
            const fill = document.getElementById('bat-fill');
            fill.style.height = `${pct}%`;
            document.getElementById('pct-val').innerText = `${pct}%`;

            if (pct < 20) fill.style.background = '#ef4444';
            else if (pct < 50) fill.style.background = '#fb923c';
            else fill.style.background = '#10b981';

            document.getElementById('overall-status').innerText = pct === 100 ? 'جاهز للاختبار! ✅' : `${totalDoneOverall} من ${totalPagesOverall} صفحة`;

            const now = new Date();
            const d1 = Math.ceil((new Date(examDates.period1) - now) / (1000 * 60 * 60 * 24));
            const d2 = Math.ceil((new Date(examDates.period2) - now) / (1000 * 60 * 60 * 24));
            document.getElementById('countdown-1').innerText = d1 > 0 ? d1 : 0;
            document.getElementById('countdown-2').innerText = d2 > 0 ? d2 : 0;

            localStorage.setItem('study_v17', JSON.stringify(storage));
        }

        function tab(s) {
            document.querySelectorAll('.subject-page').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.nav-link').forEach(b => b.classList.remove('active'));
            document.getElementById(`p-${s}`).classList.add('active');
            document.getElementById(`b-${s}`).classList.add('active');
        }

        function resetApp() {
            if (confirm("هل أنت متأكد؟ سيتم مسح جميع عدد الصفحات التي أنجزتها والبدء من الصفر.")) {
                storage.prog = {};
                localStorage.setItem('study_v17', JSON.stringify(storage));
                init();
            }
        }

        init();
    </script>
</body>
</html>
